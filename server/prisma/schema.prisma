generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  RECURRING
  BATCH
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum QueueStatus {
  ACTIVE
  PAUSED
}

enum WorkerStatus {
  ONLINE
  OFFLINE
  DRAINING
}

enum Role {
  ADMIN
  MEMBER
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

// ---------- CORE ----------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  memberships ProjectMember[]

  @@index([email])
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  queues  Queue[]
  members ProjectMember[]

  @@index([organizationId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  role      Role     @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
}

// ---------- QUEUE ----------

model Queue {
  id               String        @id @default(uuid())
  name             String
  projectId        String
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  priority         Int           @default(0)
  concurrencyLimit Int           @default(5)
  status           QueueStatus   @default(ACTIVE)
  retryPolicyId    String?
  retryPolicy      RetryPolicy?  @relation(fields: [retryPolicyId], references: [id])
  createdAt        DateTime      @default(now())

  jobs          Job[]
  scheduledJobs ScheduledJob[]

  @@index([projectId])
  @@unique([projectId, name])
}

model RetryPolicy {
  id           String        @id @default(uuid())
  name         String
  strategy     RetryStrategy @default(EXPONENTIAL)
  baseDelayMs  Int           @default(1000)
  maxAttempts  Int           @default(5)
  createdAt    DateTime      @default(now())

  queues Queue[]
}

// ---------- JOBS ----------

model Job {
  id            String    @id @default(uuid())
  queueId       String
  queue         Queue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  type          JobType
  payload       Json
  status        JobStatus @default(QUEUED)
  priority      Int       @default(0)
  runAt         DateTime  @default(now())
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  batchId       String?
  cronExpr      String?
  workerId      String?
  worker        Worker?   @relation(fields: [workerId], references: [id])
  claimedAt     DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  executions JobExecution[]
  logs       JobLog[]
  dlqEntry   DeadLetterQueue?

  @@index([status, runAt])
  @@index([queueId, priority, createdAt])
  @@index([batchId])
}

model JobExecution {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId    String?
  worker      Worker?   @relation(fields: [workerId], references: [id])
  attemptNo   Int
  status      JobStatus
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  error       String?

  @@index([jobId])
  @@index([workerId])
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level     LogLevel @default(INFO)
  message   String
  createdAt DateTime @default(now())

  @@index([jobId])
}

model ScheduledJob {
  id         String   @id @default(uuid())
  queueId    String
  queue      Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  cronExpr   String
  payload    Json
  nextRunAt  DateTime
  lastRunAt  DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([nextRunAt])
  @@index([queueId])
}

model DeadLetterQueue {
  id       String   @id @default(uuid())
  jobId    String   @unique
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reason   String
  movedAt  DateTime @default(now())
}

// ---------- WORKERS ----------

model Worker {
  id             String         @id @default(uuid())
  hostname       String
  status         WorkerStatus   @default(ONLINE)
  lastHeartbeat  DateTime       @default(now())
  createdAt      DateTime       @default(now())

  jobs        Job[]
  executions  JobExecution[]
  heartbeats  WorkerHeartbeat[]

  @@index([status])
}

model WorkerHeartbeat {
  id        String   @id @default(uuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  metrics   Json?
  createdAt DateTime @default(now())

  @@index([workerId, createdAt])
}